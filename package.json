{
  "name": "vue3-smart-table",
  "version": "0.1.0",
  "files": [
    "dist"
  ],
  "main": "./dist/vue3-smart-table.umd.js",
  "module": "./dist/vue3-smart-table.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/vue3-smart-table.mjs",
      "require": "./dist/vue3-smart-table.umd.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && yarn run tsDeclaration",
    "tsDeclaration": "tsc -p tsconfig.json -d --outDir dist/types --emitDeclarationOnly",
    "serve": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:dev": "vuepress dev docs",
    "docs:build": "vuepress build docs",
    "docs:serve": "vuepress serve docs"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/compiler-sfc": "^3.5.0",
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^17.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0",
    "vuepress": "^2.0.0-beta.8"
  }
}
